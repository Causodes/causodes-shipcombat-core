{
  "id": "causodes-shipcombat-core",
  "title": "Causodes's Ship Combat (Core)",
  "description": "<p>System-agnostic ship combat engine for Foundry VTT. Provides the bridge-crew framework, socket protocol, canvas overlays, and template infrastructure. Requires a system-specific companion module (e.g. Causodes's Ship Combat (Imperium Maledictum)) to activate.</p>",
  "version": "2.1.0",
  "compatibility": {
    "minimum": "13",
    "verified": "14.361",
    "maximum": "14"
  },
  "authors": [
    {
      "name": "Causodes",
      "flags": {}
    }
  ],
  "socket": true,
  "relationships": {
    "requires": [
      {
        "id": "socketlib",
        "type": "module",
        "manifest": "https://github.com/farling42/foundryvtt-socketlib/releases/latest/download/module.json"
      }
    ],
    "optional": [
      {
        "id": "sequencer",
        "type": "module",
        "reason": "Enables animated weapon effects on the canvas."
      },
      {
        "id": "jb2a_patreon",
        "type": "module",
        "reason": "Provides the JB2A asset library used by the optional animations."
      }
    ]
  },
  "esmodules": [
    "causodes-shipcombat-core.js"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "hbs",
        "json"
      ]
    }
  },
  "url": "https://github.com/Causodes/causodes-shipcombat-core",
  "download": "https://github.com/Causodes/causodes-shipcombat-core/archive/refs/tags/v2.1.0.zip",
  "manifest": "https://github.com/Causodes/causodes-shipcombat-core/releases/latest/download/module.json",
  "readme": "https://github.com/Causodes/causodes-shipcombat-core/blob/main/README.md",
  "changelog": "https://github.com/Causodes/causodes-shipcombat-core/blob/main/CHANGELOG.md",
  "allowBugReporter": true,
  "styles": [
    "styles/custom-class-compat.css",
    "styles/appv1-compact.css",
    "styles/header.css",
    "styles/overview.css",
    "styles/engineer.css",
    "styles/captain.css",
    "styles/popup.css",
    "styles/gunner.css",
    "styles/pilot.css",
    "styles/components.css",
    "styles/sensors.css",
    "styles/npc.css",
    "styles/ordnance.css",
    "styles/torpedo.css",
    "styles/chat.css"
  ]
}

{{!-- fire-result.hbs  -  B2 chat card for weapon fire results --}}
<div class="shipcombat-fire-result">
    <div class="shipcombat-fire-header">
        <img src="{{weaponImg}}" class="shipcombat-fire-icon">
        <div class="shipcombat-fire-title">
            <strong>{{weaponName}}</strong>
            <span class="shipcombat-fire-mode">{{fireModeLabel}}</span>
        </div>
    </div>

    <div class="shipcombat-fire-target-row">
        <i class="fa-solid fa-crosshairs"></i>
        <span>{{targetName}}</span>
        <span class="shipcombat-fire-quadrant">({{hitQuadrantLabel}})</span>
    </div>

    {{!-- ═══ Salvo Summary ═══ --}}
    {{#if totalSalvo}}
    <div class="shipcombat-fire-salvo-summary">
        <div class="shipcombat-fire-detail">
            <i class="fa-solid fa-burst"></i>
            <strong>{{totalHits}}</strong> / {{totalSalvo}} {{localize "SHIPCOMBAT.Fire.ShotsHit"}}
            {{#if guaranteedHits}}
                <span class="shipcombat-fire-guaranteed">({{guaranteedHits}} {{localize "SHIPCOMBAT.Fire.Guaranteed"}})</span>
            {{/if}}
            {{#if accuracy}}
                <span class="shipcombat-fire-tn-inline">vs {{accuracy}}</span>
            {{/if}}
        </div>
    </div>
    {{/if}}

    {{!-- ═══ Salvo Dice (individual rolls, batched by salvo size) ═══ --}}
    {{#if hasSalvoRolls}}
    <div class="shipcombat-fire-salvo-rolls">
        {{#each salvoRolls}}
        {{#if this.batchBreak}}<span class="shipcombat-salvo-batch-sep"></span>{{/if}}
        <span class="shipcombat-salvo-die shipcombat-salvo-reveal {{#if this.hit}}shipcombat-fire-success{{else}}shipcombat-fire-failure{{/if}} {{#if this.isJam}}shipcombat-salvo-jam{{/if}}"
              style="{{{this.dieStyle}}}"
              title="{{this.roll}} vs {{this.target}}">
            {{this.roll}}
        </span>
        {{/each}}
    </div>
    {{/if}}

    {{!-- ═══ Jam Warning ═══ --}}
    {{#if jammed}}
    <div class="shipcombat-fire-jam shipcombat-summary-reveal" style="animation-delay:{{summaryDelay}}ms">
        <i class="fa-solid fa-triangle-exclamation"></i>
        {{localize "SHIPCOMBAT.Fire.Jammed"}}
    </div>
    {{/if}}

    {{!-- ═══ Shield Resolution ═══ --}}
    {{#if hasShieldResults}}
    <div class="shipcombat-fire-shields shipcombat-summary-reveal" style="animation-delay:{{summaryDelay}}ms">
        <i class="fa-solid fa-shield-halved"></i>
        {{#if shieldResults.bypassed}}
            <span class="shipcombat-shield-bypass">{{localize "SHIPCOMBAT.Fire.ShieldBypassed"}}</span>
        {{else}}
            <span>{{shieldResults.absorbed}} {{localize "SHIPCOMBAT.Fire.Absorbed"}} ({{shieldResults.shieldCostTotal}} {{localize "SHIPCOMBAT.Fire.ShieldDrain"}})</span>
            <span class="shipcombat-shield-through">→ {{shieldResults.hitsThroughShield}} {{localize "SHIPCOMBAT.Fire.Through"}}</span>
        {{/if}}
    </div>
    {{/if}}

    {{!-- ═══ Damage Resolution ═══ --}}
    {{#if hasDamageResults}}
    <div class="shipcombat-fire-damage shipcombat-summary-reveal" style="animation-delay:{{summaryDelay}}ms">
        {{#if damageResults.totalDamage}}
        <div class="shipcombat-fire-damage-header">
            <i class="fa-solid fa-explosion"></i>
            <strong>{{damageResults.totalDamage}}</strong> {{localize "SHIPCOMBAT.Fire.HullDamage"}}
        </div>
        <div class="shipcombat-fire-damage-detail">
            {{damageResults.damagePerHit}} {{localize "SHIPCOMBAT.Fire.PerHit"}}
            ({{damageResults.rawDamagePerHit}} − {{damageResults.effectiveArmour}} {{localize "SHIPCOMBAT.Fire.Armour"}})
            {{#if damageResults.ap}}
                <span class="shipcombat-fire-ap">[AP {{damageResults.ap}}]</span>
            {{/if}}
        </div>
        {{else}}
        <div class="shipcombat-fire-damage-header shipcombat-fire-armour-blocked">
            <i class="fa-solid fa-shield"></i>
            {{localize "SHIPCOMBAT.Fire.BlockedByArmour"}}
        </div>
        <div class="shipcombat-fire-damage-detail">
            {{damageResults.rawDamagePerHit}} − {{damageResults.effectiveArmour}} {{localize "SHIPCOMBAT.Fire.Armour"}}
            {{#if damageResults.ap}}
                <span class="shipcombat-fire-ap">[AP {{damageResults.ap}}]</span>
            {{/if}}
        </div>
        {{/if}}
        {{#if damageResults.rendTotal}}
        <div class="shipcombat-fire-rend">
            <i class="fa-solid fa-hammer"></i>
            {{localize "SHIPCOMBAT.Fire.Rend"}}: −{{damageResults.rendTotal}} {{localize "SHIPCOMBAT.Fire.SectorArmour"}}
        </div>
        {{/if}}
    </div>
    {{/if}}

    {{!-- ═══ Resource Cost ═══ --}}
    {{#if resourceCost}}
    <div class="shipcombat-fire-details shipcombat-summary-reveal" style="animation-delay:{{summaryDelay}}ms">
        <span class="shipcombat-fire-detail shipcombat-fire-cost">
            {{resourceCost}}
        </span>
    </div>
    {{/if}}

    {{!-- ═══ Critical Hit ═══ --}}
    {{#if critResult.hasCrit}}
    <div class="shipcombat-fire-crit shipcombat-summary-reveal" style="animation-delay:{{summaryDelay}}ms">
        <div class="shipcombat-fire-crit-header">
            <i class="fa-solid fa-skull"></i>
            <strong>{{localize "SHIPCOMBAT.Crit.Hit"}}</strong>
            <span class="shipcombat-crit-tier-badge shipcombat-crit-tier--{{critResult.finalTier}}">{{critResult.tierLabel}}</span>
        </div>
        <div class="shipcombat-fire-crit-detail">
            <span class="shipcombat-crit-location-label">{{critResult.locLabel}}</span>
            <span class="shipcombat-crit-sep">  -  </span>
            <span class="shipcombat-crit-condition-label">{{critResult.condLabel}}</span>
        </div>
        {{#if critResult.detail}}
        <div class="shipcombat-fire-crit-note">{{critResult.detail}}</div>
        {{/if}}
    </div>
    {{/if}}
</div>

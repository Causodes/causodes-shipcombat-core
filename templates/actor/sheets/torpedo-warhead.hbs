<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">
<div class="shipcombat-torpedo-sheet">

    {{> "vessel-trait-summary"}}

    {{!-- Movement Controls --}}
    <div class="shipcombat-torpedo-movement">
        {{> "vessel-movement-controls"}}
    </div>

    {{!-- Detonate --}}
    <div class="shipcombat-torpedo-detonate">
        {{#if sys.designated}}
        <button type="button" data-action="detonate" class="shipcombat-detonate-btn" disabled
            data-tooltip="Torpedo has been designated — detonation is locked this round.">
            <i class="fas fa-lock"></i> Detonate
        </button>
        {{else}}
        <button type="button" data-action="detonate" class="shipcombat-detonate-btn">
            <i class="fas fa-explosion"></i> Detonate
        </button>
        {{/if}}
    </div>

    {{> "vessel-turn-complete"}}

</div>
</section>

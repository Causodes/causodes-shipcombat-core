<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">
<div class="shipcombat-torpedo-sheet">

    {{!-- Warhead Count --}}
    <div class="shipcombat-torpedo-bar">
        <label>Warheads</label>
        <div class="shipcombat-torpedo-bar-track">
            <div class="shipcombat-torpedo-bar-fill hull" style="width: {{hullPct}}%"></div>
            <span class="shipcombat-torpedo-bar-text">
                <input type="number" name="system.hull.value" value="{{sys.hull.value}}" class="shipcombat-torpedo-inline" />
                /
                <input type="number" name="system.hull.max" value="{{sys.hull.max}}" class="shipcombat-torpedo-inline" />
            </span>
        </div>
    </div>

    {{!-- Fuel --}}
    <div class="shipcombat-torpedo-bar">
        <label>Fuel</label>
        <div class="shipcombat-torpedo-bar-track">
            <div class="shipcombat-torpedo-bar-fill fuel" style="width: {{fuelPct}}%"></div>
            <span class="shipcombat-torpedo-bar-text">
                <input type="number" name="system.fuel.value" value="{{sys.fuel.value}}" class="shipcombat-torpedo-inline" />
                /
                <input type="number" name="system.fuel.max" value="{{sys.fuel.max}}" class="shipcombat-torpedo-inline" />
            </span>
        </div>
    </div>

    {{!-- Movement + Payload stats --}}
    <div class="shipcombat-torpedo-stats">
        <div class="shipcombat-torpedo-stat">
            <label>SPD</label>
            <input type="number" name="system.movement.speed" value="{{sys.movement.speed}}" />
        </div>
        <div class="shipcombat-torpedo-stat">
            <label>MAN</label>
            <input type="number" name="system.movement.maneuverability" value="{{sys.movement.maneuverability}}" />
        </div>
        {{#unless useDiceBreakdown}}
        <div class="shipcombat-torpedo-stat">
            <label>COUNT</label>
            <input type="number" name="system.payloadDiceCount" value="{{sys.payloadDiceCount}}" placeholder="—" />
        </div>
        <div class="shipcombat-torpedo-stat">
            <label>SIZE</label>
            <input type="text" name="system.payloadDiceSize" value="{{sys.payloadDiceSize}}" placeholder="—" />
        </div>
        <div class="shipcombat-torpedo-stat">
            <label>TYPE</label>
            <input type="text" name="system.payloadDamageType" value="{{sys.payloadDamageType}}" placeholder="—" />
        </div>
        {{/unless}}
        <div class="shipcombat-torpedo-stat">
            <label>RADIUS</label>
            <input type="number" name="system.payloadRadius" value="{{sys.payloadRadius}}" />
        </div>
        {{#if showArmorClass}}
        <div class="shipcombat-torpedo-stat">
            <label data-tooltip="Armor Class — used as the attack target for incoming fire" data-tooltip-direction="UP">AC</label>
            <input type="number" name="system.armorClass" value="{{sys.armorClass}}" />
        </div>
        {{/if}}
    </div>
    {{#if useDiceBreakdown}}
    {{!-- SF2e structured damage (count · die size · damage type) --}}
    <div class="shipcombat-torpedo-traits shipcombat-torpedo-traits--damage">
        <h4>{{localize "SHIPCOMBAT.Label.Damage"}}</h4>
        <div class="shipcombat-payload-dmg-trio">
            <input type="number" name="system.payloadDiceCount" value="{{sys.payloadDiceCount}}" min="1" placeholder="—" />
            <select name="system.payloadDiceSize">
                <option value="">—</option>
                {{#each diceOptions}}<option value="{{this.value}}" {{#if (eq this.value @root.sys.payloadDiceSize)}}selected{{/if}}>{{this.label}}</option>{{/each}}
            </select>
            <select name="system.payloadDamageType">
                <option value="">—</option>
                {{#each damageTypeChoices}}<option value="{{this.value}}" {{#if (eq this.value @root.sys.payloadDamageType)}}selected{{/if}}>{{this.label}}</option>{{/each}}
            </select>
        </div>
    </div>
    {{/if}}

    {{> "vessel-weapon-traits" title="Warhead Traits"}}

</div>
</section>

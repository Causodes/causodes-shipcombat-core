{{!-- tabs/3/engineer.hbs — Engineer / Helmsman merged station tab (<= 3 players) --}}
{{!-- Handles Engineer + Pilot roles. Helm allocation uses Engineering (Tech) skill. --}}
{{!-- Overcharged Power Core actions (Overdrive / Strafe / Retrograde) are not included --}}
{{!-- at this crew size; the single core the Engineer receives goes to reactor management. --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">

    {{> "engineer-claim-prompt"}}

    {{#if (or isGM (lookup (lookup roles "engineer") "isMyRole"))}}
    {{> "engineer-captain-boost"}}
    {{> "engineer-status-bar"}}

    {{!-- VOID SHIELD MANAGEMENT --}}
    {{> "captain-voidshields"}}

    {{!-- HELM CONTROL (directly under voidshields; roll uses Engineering in 3-man) --}}
    {{> "pilot-helm-control"}}

    {{!-- REACTOR MANAGEMENT --}}
    {{> "engineer-core-distribution"}}
    {{> "engineer-heat-management"}}
    {{> "engineer-fire-suppression"}}
    {{> "engineer-hull-repair"}}
    {{/if}}

    {{> 'complete-turn' tabRoleId="engineer" turnDone=(lookup @root.sys.turnDone "engineer")}}

</section>

{{!-- Pilot: Status Bar (aux power) --}}
<div class="sheet-list shipcombat-role-status-bar">
    <div class="list-header row-content">
        <div class="list-name">{{localize "SHIPCOMBAT.Helm.AuxPowerTitle"}}</div>
        {{#with (lookup roles "pilot")}}
        {{> "payload-status-badge"
            payloadId=payloadId payloadLabel=payloadLabel payloadDesc=payloadDesc}}
        {{> "core-status-banner"
            coreCount=coreCount coreActionsPlayedLabels=@root.helm.coreActionsPlayedLabels hasCoreStaged=hasCoreStaged}}
        {{/with}}
    </div>
    <div class="list-content">
        <div class="shipcombat-role-status-panel">
            <div class="shipcombat-resource-bar-row">
                <span class="shipcombat-resource-bar-label">{{localize "SHIPCOMBAT.Engineer.CoreBank"}}</span>
                <div class="shipcombat-resource-bar-track shipcombat-resource-bar-track--plasma">
                    <div class="shipcombat-resource-bar-fill" style="width: {{helm.auxPowerPct}}%"></div>
                </div>
                <span class="shipcombat-resource-bar-value shipcombat-resource-bar-value--plasma">{{helm.auxiliaryPower}}/{{helm.auxPowerCapacity}}</span>
            </div>
        </div>
    </div>
</div>

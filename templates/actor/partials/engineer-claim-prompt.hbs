{{!-- Engineer: Role claim prompt --}}
{{#with (lookup roles "engineer")}}
{{#unless isMyRole}}
    {{#unless @root.isGM}}
    <div class="sheet-list">
        <div class="list-content">
            <div class="list-row">
                <div class="row-content">
                    <div class="list-name">{{localize "SHIPCOMBAT.Prompt.ClaimRole"}}</div>
                    <div class="list-controls">
                        <button data-action="claimRole" data-role-id="engineer">
                            <i class="fa-solid fa-gears"></i> {{labelLocalized}}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{/unless}}
{{/unless}}
{{/with}}

{{!-- Ordnance: Deployed Torpedoes (5-man Supreme Commander tab) --}}
<div class="sheet-list shipcombat-deployed-ordnance">
    <div class="list-header row-content">
        <div class="list-name">{{localize "SHIPCOMBAT.Ordnance.DeployedTorpedoes"}} ({{ordnanceCtx.deployedTorpedoCount}})</div>
    </div>
    <div class="list-content">
        {{#unless ordnanceCtx.deployedTorpedoCount}}
        <div class="shipcombat-deployed-empty">
            {{localize "SHIPCOMBAT.Ordnance.NoneDeployedTorpedoes"}}
        </div>
        {{/unless}}

        {{#each ordnanceCtx.deployedTorpedoes}}
        <div class="shipcombat-deployed-row shipcombat-deployed--torpedo {{#if turnComplete}}shipcombat-deployed--done{{/if}}"
             data-token-id="{{tokenId}}">
            <img src="{{img}}" class="shipcombat-deployed-icon" />
            <span class="shipcombat-deployed-name">{{name}}</span>
            <span class="shipcombat-deployed-type"><i class="fa-solid fa-rocket"></i></span>
            <div class="shipcombat-deployed-controls">
                <button type="button" data-action="panToOrdnance" data-token-id="{{tokenId}}"
                        data-tooltip="{{localize 'SHIPCOMBAT.Ordnance.PanTo'}}">
                    <i class="fa-solid fa-eye"></i>
                </button>
                <button type="button" data-action="markOrdnanceDone" data-token-id="{{tokenId}}"
                        class="{{#if turnComplete}}active{{/if}}"
                        {{#if isLaunchTurn}}disabled data-tooltip="{{localize 'SHIPCOMBAT.Ordnance.LaunchTurnLocked'}}"{{else}}data-tooltip="{{localize 'SHIPCOMBAT.Ordnance.MarkDone'}}"{{/if}}>
                    <i class="{{#if turnComplete}}fa-solid fa-circle-check{{else}}fa-regular fa-circle{{/if}}"></i>
                </button>
            </div>
        </div>
        {{/each}}
    </div>
</div>

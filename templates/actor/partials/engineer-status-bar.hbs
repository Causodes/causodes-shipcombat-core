{{!-- Engineer: Status Bar (heat + aux power) --}}
<div class="sheet-list shipcombat-role-status-bar">
    <div class="list-header row-content">
        <div class="list-name">{{localize "SHIPCOMBAT.Engineer.StatusTitle"}}</div>
        {{#with (lookup roles "engineer")}}
        {{> "payload-status-badge"
            payloadId=payloadId payloadLabel=payloadLabel payloadDesc=payloadDesc}}
        {{/with}}
    </div>
    <div class="list-content">
        <div class="shipcombat-role-status-panel">
            <div class="shipcombat-resource-bar-row">
                <span class="shipcombat-resource-bar-label">{{localize "SHIPCOMBAT.Resource.Heat"}}</span>
                <div class="shipcombat-resource-bar-track shipcombat-resource-bar-track--heat">
                    <div class="shipcombat-resource-bar-fill-cover" style="width: calc(100% - {{engineerCtx.heatPct}}%)"></div>
                </div>
                <span class="shipcombat-resource-bar-value" style="color: {{engineerCtx.heatColor}}">{{engineerCtx.heat}}/{{engineerCtx.heatMax}}</span>
            </div>
            <div class="shipcombat-resource-bar-row">
                <span class="shipcombat-resource-bar-label">{{localize "SHIPCOMBAT.Engineer.CoreBank"}}</span>
                <div class="shipcombat-resource-bar-track shipcombat-resource-bar-track--plasma">
                    <div class="shipcombat-resource-bar-fill" style="width: {{engineerCtx.plasmaPct}}%"></div>
                </div>
                <span class="shipcombat-resource-bar-value shipcombat-resource-bar-value--plasma">{{engineerCtx.auxiliaryPower}}/{{engineerCtx.auxPowerCapacity}}</span>
            </div>
        </div>
    </div>
</div>

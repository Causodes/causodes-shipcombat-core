{{!-- Ordnance: Status Bar (OP + aux power + readiness cards + commitments) --}}
<div class="sheet-list shipcombat-role-status-bar">
    <div class="list-header row-content">
        <div class="list-name">{{#if statusTitle}}{{statusTitle}}{{else}}{{localize "SHIPCOMBAT.Ordnance.StatusTitle"}}{{/if}}</div>
        {{#with (lookup roles "ordnance")}}
        {{> "core-status-banner"
            coreCount=coreCount coreActionsPlayedLabels=coreActionsPlayedLabels hasCoreStaged=hasCoreStaged}}
        {{/with}}
    </div>
    <div class="list-content">
        <div class="shipcombat-role-status-panel">
            <div class="shipcombat-resource-bar-row">
                <span class="shipcombat-resource-bar-label">{{ordnanceCtx.mpLabel}}</span>
                <div class="shipcombat-resource-bar-track shipcombat-resource-bar-track--plasma">
                    <div class="shipcombat-resource-bar-fill shipcombat-bar-op" style="width: {{ordnanceCtx.mpPct}}%"></div>
                    {{#if ordnanceCtx.mpLostPct}}
                    <div class="shipcombat-bar-lost" style="left: {{ordnanceCtx.mpPct}}%; width: {{ordnanceCtx.mpLostPct}}%"></div>
                    {{/if}}
                </div>
                <span class="shipcombat-resource-bar-value" style="color: #00ff88">{{ordnanceCtx.manpower}}/{{ordnanceCtx.manpowerMax}}</span>
            </div>
            <div class="shipcombat-resource-bar-row">
                <span class="shipcombat-resource-bar-label">{{localize "SHIPCOMBAT.Sensors.PowerTrack"}}</span>
                <div class="shipcombat-resource-bar-track shipcombat-resource-bar-track--aux">
                    <div class="shipcombat-resource-bar-fill shipcombat-bar-aux" style="width: {{ordnanceCtx.auxPowerPct}}%"></div>
                </div>
                <span class="shipcombat-resource-bar-value" style="color: #7ec8e3">{{ordnanceCtx.auxPower}}/{{ordnanceCtx.auxPowerMax}}</span>
            </div>
        </div>

        {{!-- Ordnance Readiness — three side-by-side cards --}}
        <div class="shipcombat-ordnance-cards">

            {{!-- Torpedo card --}}
            <div class="shipcombat-ord-card">
                <div class="shipcombat-ord-card-header">
                    <i class="fa-solid fa-rocket"></i>
                    <span>{{localize "SHIPCOMBAT.Ordnance.Torpedoes"}}</span>
                </div>
                <div class="shipcombat-ord-card-body">
                    {{#if ordnanceCtx.readyTorpedoes}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--ready">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.readyTorpedoes}} {{localize "SHIPCOMBAT.Ordnance.Armed"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.loadingTorpedoes}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--loading">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.loadingTorpedoes}} {{localize "SHIPCOMBAT.Ordnance.Loading"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.deployedTorpedoCount}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--deployed">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.deployedTorpedoCount}} {{localize "SHIPCOMBAT.Ordnance.InFlight"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.hasTorpedoConfig}}
                    <span class="shipcombat-ord-badge {{#if (shipcombatEq ordnanceCtx.autoArmTimer 1)}}shipcombat-ord-badge--ready{{else}}shipcombat-ord-badge--loading{{/if}}"
                          data-tooltip="{{localize 'SHIPCOMBAT.Ordnance.AutoArmTooltip'}}">
                        <i class="fa-solid fa-clock"></i> {{localize 'SHIPCOMBAT.Ordnance.AutoArm'}}: {{ordnanceCtx.autoArmTimer}}T
                    </span>
                    {{/if}}
                </div>
            </div>

            {{!-- Strike Craft card --}}
            {{#if @root.useStrikeCraft}}
            <div class="shipcombat-ord-card shipcombat-ord-card--craft">
                <div class="shipcombat-ord-card-header">
                    <i class="fa-solid fa-jet-fighter"></i>
                    <span>{{localize "SHIPCOMBAT.Ordnance.StrikeCraft"}}</span>
                    <span class="shipcombat-ord-flights">{{ordnanceCtx.deployedCraftCount}}/{{ordnanceCtx.maxFlights}}</span>
                </div>
                <div class="shipcombat-ord-card-body">
                    <div class="shipcombat-ordnance-pips">
                        {{#each ordnanceCtx.craftPips}}
                        <div class="shipcombat-ordnance-pip shipcombat-ordnance-pip--{{state}}"></div>
                        {{/each}}
                    </div>
                </div>
            </div>
            {{/if}}

            {{!-- Payload card --}}
            <div class="shipcombat-ord-card">
                <div class="shipcombat-ord-card-header">
                    <i class="fa-solid fa-box"></i>
                    <span>{{localize "SHIPCOMBAT.Ordnance.Payloads"}}</span>
                </div>
                <div class="shipcombat-ord-card-body">
                    {{#if ordnanceCtx.activePayloadCount}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--ready">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.activePayloadCount}} {{localize "SHIPCOMBAT.Ordnance.Active"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.loadingPayloadCount}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--deployed">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.loadingPayloadCount}} {{localize "SHIPCOMBAT.Ordnance.Loading"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.availablePayloads}}
                    <span class="shipcombat-ord-badge shipcombat-ord-badge--ready">
                        <i class="fa-solid fa-circle"></i> {{ordnanceCtx.availablePayloads}} {{localize "SHIPCOMBAT.Ordnance.Available"}}
                    </span>
                    {{/if}}
                    {{#if ordnanceCtx.manpowerMax}}
                    <span class="shipcombat-ord-badge {{#if (shipcombatEq ordnanceCtx.autoLoadTimer 1)}}shipcombat-ord-badge--ready{{else}}shipcombat-ord-badge--loading{{/if}}"
                          data-tooltip="{{localize 'SHIPCOMBAT.Ordnance.AutoLoadTooltip'}}">
                        <i class="fa-solid fa-clock"></i> {{localize 'SHIPCOMBAT.Ordnance.AutoLoad'}}: {{ordnanceCtx.autoLoadTimer}}T
                    </span>
                    {{/if}}
                </div>
            </div>

        </div>

        {{!-- Active Commitments (condensed inline) --}}
        {{#if ordnanceCtx.commitments.length}}
        <div class="shipcombat-commitments-inline">
            {{#each ordnanceCtx.commitments}}
            <span class="shipcombat-commitment-pill {{#if isNew}}shipcombat-commitment-pill--new{{/if}} {{#if noCancel}}shipcombat-commitment-pill--locked{{/if}}"
                  data-tooltip="{{actionLabel}}  -  {{crewCount}} crew, {{turnsRemaining}} turn(s) left{{#if completionBenefit}} | Benefit awarded on completion{{/if}}{{#if isNew}}{{#if noCancel}} | Cannot cancel: effect already applied{{else}} | Right-click to cancel{{/if}}{{/if}}"
                  data-index="{{index}}">
                <i class="{{icon}}"></i> {{crewCount}}<i class="fa-solid fa-user fa-xs"></i> {{turnsRemaining}}T{{#if noCancel}}<i class="fa-solid fa-lock fa-xs" style="margin-left:2px;opacity:0.6"></i>{{/if}}
            </span>
            {{/each}}
        </div>
        {{/if}}
    </div>
</div>
